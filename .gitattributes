# Normalize line endings to avoid mixed CRLF/LF churn across platforms.
* text=auto eol=lf

# Source files that tooling (gofmt, eslint, prettier) expects to be LF.
*.go    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets should never be normalized.
*.png   binary
*.jpg   binary
*.svg   text eol=lf
