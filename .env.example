# Copy this file to .env and fill in real values.
# The backend loads .env automatically on startup (via godotenv); variables
# already present in the environment (e.g. from docker-compose) take precedence.

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=initiative_user
DB_PASSWORD=initiative_pass
DB_NAME=initiative_db
# sslmode for the postgres connection; "disable" is fine for local dev.
SSLMODE=disable

# --- Server ---
# Port the Go backend listens on (defaults to 8080 if unset).
PORT=8080
# URL of the frontend; used for redirects and CORS (defaults to http://localhost:5173).
FRONTEND_URL=http://localhost:5173
# Set to "true" in production (HTTPS) so auth cookies are marked Secure.
SECURE_COOKIES=false
# Secret used to HMAC-sign the session (discord_id) cookie. Set a long random
# value in production; if unset, an ephemeral one is generated and logins are
# invalidated on every restart. Generate one with e.g. `openssl rand -hex 32`.
SESSION_SECRET=

# --- Discord OAuth ---
# Create an application at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Must match the redirect URI configured in your Discord application.
DISCORD_REDIRECT_URL=http://localhost:8080/auth/discord/callback
