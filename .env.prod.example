# Production environment for docker-compose.prod.yml (Cloudflare Tunnel deploy).
# Copy to .env next to the compose file and fill in real values:
#   cp .env.prod.example .env
# Never commit the filled-in .env.

# --- Database ---
# Strong random password for Postgres. Generate one, e.g. `openssl rand -hex 24`.
DB_PASSWORD=

# --- Session ---
# Long, stable random value used to HMAC-sign the session cookie.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# --- Public site URL ---
# Your domain served through Cloudflare. No trailing slash.
FRONTEND_URL=https://your-domain.example

# --- Discord OAuth ---
# From https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must match a redirect URI registered in the Discord app EXACTLY.
# Note the /api prefix: Caddy strips it before the backend sees the route.
DISCORD_REDIRECT_URL=https://your-domain.example/api/auth/discord/callback

# --- Cloudflare Tunnel ---
# Token shown when you create a tunnel in the Zero Trust dashboard
# (Networks > Tunnels > your tunnel > Install connector).
TUNNEL_TOKEN=

# --- DietPi dashboard subdomain (optional) ---
# Host that Caddy routes to the host-based DietPi dashboard (port 5252). Set
# this to expose the dashboard at its own subdomain; add a matching Public
# Hostname in the tunnel (-> caddy:80) and gate it with Cloudflare Access.
# Leave unset/blank to disable the route entirely. See DEPLOY.md.
DIETPI_HOSTNAME=dietpi.your-domain.example
